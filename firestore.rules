rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "aminehasni20@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isWarehouseman() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'warehouseman';
    }
    
    function isNotPaused() {
      return isAuthenticated() && (
        request.auth.token.email == "aminehasni20@gmail.com" || 
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
        getUserData().role == 'admin' || 
        getUserData().get('isPaused', false) == false
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || resource.data.role in ['admin', 'warehouseman']);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Logs collection
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Main business collections
    match /products/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow delete: if (isAdmin() || isWarehouseman()) && isNotPaused();
    }
    
    match /clients/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if isNotPaused() && (
        isAdmin() || 
        (isWarehouseman() && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['creditLimit'])))
      );
      allow delete: if (isAdmin() || isWarehouseman()) && isNotPaused();
    }
    
    match /suppliers/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow delete: if isAdmin() && isNotPaused();
    }
    
    match /warehouses/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow write: if isAdmin() && isNotPaused();
    }
    
    match /payments/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if isAdmin() && isNotPaused();
      allow delete: if isAdmin() && isNotPaused();
    }
    
    match /stock_entries/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if isAdmin() && isNotPaused();
      allow delete: if isAdmin() && isNotPaused();
    }
    
    match /stock_exits/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if isAdmin() && isNotPaused();
      allow delete: if isAdmin() && isNotPaused();
    }
    
    match /stock_history/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if isAdmin() && isNotPaused();
      allow delete: if isAdmin() && isNotPaused();
    }

    match /expenses/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if isAuthenticated() && (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if isAuthenticated() && isAdmin() && isNotPaused();
      allow delete: if isAuthenticated() && (isAdmin() || isWarehouseman()) && isNotPaused();
    }

    match /services/{id} {
      allow read: if isAuthenticated() && isNotPaused();
      allow create: if isAuthenticated() && (isAdmin() || isWarehouseman()) && isNotPaused();
      allow update: if isAuthenticated() && isAdmin() && isNotPaused();
      allow delete: if isAuthenticated() && (isAdmin() || isWarehouseman()) && isNotPaused();
    }

    match /reclamations/{id} {
      allow read: if isAuthenticated() && isNotPaused() && (isAdmin() || request.auth.uid == resource.data.submittedBy);
      allow create: if isAuthenticated() && isNotPaused() && request.auth.uid == request.resource.data.submittedBy;
      allow update: if isAuthenticated() && isNotPaused() && (
        isAdmin() || 
        (request.auth.uid == resource.data.submittedBy && resource.data.status == 'pending')
      );
      allow delete: if isAuthenticated() && isNotPaused() && (
        isAdmin() || 
        (request.auth.uid == resource.data.submittedBy && resource.data.status == 'pending')
      );
    }

    // Catch-all for other paths
    match /{path=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
